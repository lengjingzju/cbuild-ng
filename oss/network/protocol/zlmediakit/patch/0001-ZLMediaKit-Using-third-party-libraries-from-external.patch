-
-  update_cached_list(MK_LINK_LIBRARIES MediaServer::flv MediaServer::mov)
-
-  if (ENABLE_MP4)
-    message(STATUS "ENABLE_MP4 defined")
-    update_cached_list(MK_COMPILE_DEFINITIONS ENABLE_MP4)
-  endif ()
-endif ()
-
-# 添加 mpeg 用于支持 ts 生成
-if(ENABLE_RTPPROXY OR ENABLE_HLS)
-  # mpeg
-  set(MediaServer_MPEG_ROOT ${MediaServer_ROOT}/libmpeg)
-  aux_source_directory(${MediaServer_MPEG_ROOT}/include MPEG_SRC_LIST)
-  aux_source_directory(${MediaServer_MPEG_ROOT}/source  MPEG_SRC_LIST)
-  add_library(mpeg STATIC ${MPEG_SRC_LIST})
-  add_library(MediaServer::mpeg ALIAS mpeg)
-  # media-server库相关编译宏
-  # MPEG_H26X_VERIFY - 视频流类型识别
-  # MPEG_ZERO_PAYLOAD_LENGTH - 兼容hik流
-  # MPEG_DAHUA_AAC_FROM_G711 - 兼容dahua流
-  target_compile_options(mpeg
-    PRIVATE ${COMPILE_OPTIONS_DEFAULT} -DMPEG_H26X_VERIFY -DMPEG_ZERO_PAYLOAD_LENGTH -DMPEG_DAHUA_AAC_FROM_G711)
-  target_include_directories(mpeg
-    PRIVATE
-      "$<BUILD_INTERFACE:${MediaServer_MPEG_ROOT}/include>"
-    PUBLIC
-      "$<BUILD_INTERFACE:${MediaServer_MPEG_ROOT}/include>")
-
-  update_cached_list(MK_LINK_LIBRARIES MediaServer::mpeg)
-  if(ENABLE_RTPPROXY)
-    message(STATUS "ENABLE_RTPPROXY defined")
-    update_cached_list(MK_COMPILE_DEFINITIONS ENABLE_RTPPROXY)
-  endif()
-  if(ENABLE_HLS)
-    message(STATUS "ENABLE_HLS defined")
-    update_cached_list(MK_COMPILE_DEFINITIONS ENABLE_HLS)
-  endif()
-endif()
+# ============================================================
+# media-server (mov / flv / mpeg)
+# ============================================================
+
+# -----------------------------
+# mov
+# -----------------------------
+find_path(MOV_INCLUDE_DIR mov-format.h
+    PATH_SUFFIXES include/media-server/libmov)
+
+find_library(MOV_LIBRARY mov
+    PATH_SUFFIXES lib)
+
+add_library(mov STATIC IMPORTED GLOBAL)
+add_library(MediaServer::mov ALIAS mov)
+set_target_properties(mov PROPERTIES
+    IMPORTED_LOCATION "${MOV_LIBRARY}"
+    INTERFACE_INCLUDE_DIRECTORIES "${MOV_INCLUDE_DIR}"
+)
+
+# -----------------------------
+# flv
+# -----------------------------
+find_path(FLV_INCLUDE_DIR flv-header.h
+    PATH_SUFFIXES include/media-server/libflv)
+
+find_library(FLV_LIBRARY flv
+    PATH_SUFFIXES lib)
+
+add_library(flv STATIC IMPORTED GLOBAL)
+add_library(MediaServer::flv ALIAS flv)
+set_target_properties(flv PROPERTIES
+    IMPORTED_LOCATION "${FLV_LIBRARY}"
+    INTERFACE_INCLUDE_DIRECTORIES "${FLV_INCLUDE_DIR}"
+)
+
+# -----------------------------
+# mpeg
+# -----------------------------
+find_path(MPEG_INCLUDE_DIR mpeg-proto.h
+    PATH_SUFFIXES include/media-server/libmpeg)
 
-##############################################################################
+find_library(MPEG_LIBRARY mpeg
+    PATH_SUFFIXES lib)
+
+add_library(mpeg STATIC IMPORTED GLOBAL)
+add_library(MediaServer::mpeg ALIAS mpeg)
+set_target_properties(mpeg PROPERTIES
+    IMPORTED_LOCATION "${MPEG_LIBRARY}"
+    INTERFACE_INCLUDE_DIRECTORIES "${MPEG_INCLUDE_DIR}"
+    INTERFACE_COMPILE_DEFINITIONS
+        "MPEG_H26X_VERIFY;MPEG_ZERO_PAYLOAD_LENGTH;MPEG_DAHUA_AAC_FROM_G711"
+)
+
+update_cached_list(MK_LINK_LIBRARIES
+    MediaServer::mov
+    MediaServer::flv
+    MediaServer::mpeg
+)
+
+# ============================================================
+# ZLToolKit
+# ============================================================
+
+find_path(ZLTOOLKIT_INCLUDE_DIR Network/Socket.h
+    PATH_SUFFIXES include/ZLToolKit)
+
+find_library(ZLTOOLKIT_LIBRARY ZLToolKit
+    PATH_SUFFIXES lib)
+
+add_library(ZLToolKit SHARED IMPORTED GLOBAL)
+set_target_properties(ZLToolKit PROPERTIES
+    IMPORTED_LOCATION "${ZLTOOLKIT_LIBRARY}"
+    INTERFACE_INCLUDE_DIRECTORIES "${ZLTOOLKIT_INCLUDE_DIR}"
+)
 
-# toolkit
-add_subdirectory(ZLToolKit)
